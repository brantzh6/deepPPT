{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "style_map.schema.json",
  "title": "Style Map",
  "type": "object",
  "additionalProperties": false,
  "required": ["theme_family", "slides"],
  "properties": {
    "theme_family": { "type": "string", "minLength": 1 },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slide_id", "page_type", "visual_anchor", "weight_center", "editable_target"],
        "properties": {
          "slide_id": { "type": "string", "minLength": 1 },
          "page_type": { "type": "string", "minLength": 1 },
          "visual_anchor": { "type": "string", "minLength": 1 },
          "weight_center": { "type": "string", "minLength": 1 },
          "density_level": { "type": "string", "enum": ["low", "medium", "high"] },
          "editable_target": { "type": "string", "minLength": 1 },
          "component_bindings": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "learned_pattern": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pattern_id", "source_references", "layout_rules", "alignment_rules"],
            "properties": {
              "pattern_id": { "type": "string", "minLength": 1 },
              "source_references": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "layout_rules": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "alignment_rules": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "highlight_grammar": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "image_usage": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "required": { "type": "boolean" },
                  "mode": {
                    "type": "string",
                    "enum": ["hero", "contextual", "texture", "none"]
                  },
                  "placement_guidance": { "type": "string" }
                }
              },
              "editable_target": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
