{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "research_output.schema.json",
  "title": "Research Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["topic", "audience", "industry", "objective", "facts", "sources"],
  "properties": {
    "topic": { "type": "string", "minLength": 1 },
    "audience": { "type": "string", "minLength": 1 },
    "industry": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement", "source_ids", "confidence"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "source_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] }
        }
      }
    },
    "interpretations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement", "supported_by"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "supported_by": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "supported_by": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "industry_constraints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "title"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["primary", "secondary", "internal"] },
          "title": { "type": "string", "minLength": 1 },
          "url": { "type": "string" }
        }
      }
    }
  }
}
