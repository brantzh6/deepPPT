{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "benchmark_gallery.schema.json",
  "title": "Benchmark Gallery",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "gallery_id",
    "description",
    "deck_id",
    "extraction_mode",
    "references",
    "pattern_cards"
  ],
  "properties": {
    "gallery_id": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "deck_id": { "type": "string", "minLength": 1 },
    "extraction_mode": {
      "type": "string",
      "enum": ["direct_slide", "documented_seed"]
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "pattern_cards": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
