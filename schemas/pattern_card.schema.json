{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pattern_card.schema.json",
  "title": "Pattern Card",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "page_type",
    "source_references",
    "narrative_roles",
    "visual_anchor",
    "weight_center",
    "layout_rules",
    "alignment_rules",
    "anti_patterns"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "page_type": { "type": "string", "minLength": 1 },
    "density_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "source_references": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "narrative_roles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "topic_fit": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "visual_anchor": { "type": "string", "minLength": 1 },
    "weight_center": { "type": "string", "minLength": 1 },
    "layout_rules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "alignment_rules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "image_usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "mode": { "type": "string", "enum": ["hero", "contextual", "texture", "none"] },
        "placement_guidance": { "type": "string" }
      }
    },
    "highlight_grammar": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "component_recipe": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "editable_target": {
      "type": "string",
      "enum": ["native_shapes_plus_text", "hybrid_native_plus_svg", "native_only"]
    },
    "anti_patterns": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "reuse_notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
