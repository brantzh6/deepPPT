{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "storyline_output.schema.json",
  "title": "Storyline Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["deck_title", "audience", "narrative"],
  "properties": {
    "deck_title": { "type": "string", "minLength": 1 },
    "audience": { "type": "string", "minLength": 1 },
    "narrative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["core_question", "chapters"],
      "properties": {
        "core_question": { "type": "string", "minLength": 1 },
        "chapters": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "title", "question", "slides"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "title": { "type": "string", "minLength": 1 },
              "question": { "type": "string", "minLength": 1 },
              "slides": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["id", "claim", "role"],
                  "properties": {
                    "id": { "type": "string", "minLength": 1 },
                    "claim": { "type": "string", "minLength": 1 },
                    "role": { "type": "string", "minLength": 1 },
                    "page_type_hint": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
