{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "slides_output.schema.json",
  "title": "Slides Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["deck_title", "slides"],
  "properties": {
    "deck_title": { "type": "string", "minLength": 1 },
    "theme_hint": { "type": "string" },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "chapter", "title", "claim", "blocks"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "chapter": { "type": "string", "minLength": 1 },
          "page_type": { "type": "string" },
          "page_type_hint": { "type": "string" },
          "title": { "type": "string", "minLength": 1 },
          "subtitle": { "type": "string" },
          "claim": { "type": "string", "minLength": 1 },
          "blocks": { "type": "object" },
          "notes": {
            "type": "object",
            "properties": {
              "audience_tone": { "type": "string" },
              "visual_anchor": { "type": "string" },
              "must_emphasize": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            },
            "additionalProperties": true
          },
          "layout_hints": {
            "type": "object",
            "properties": {
              "weight_center": { "type": "string" },
              "density_level": { "type": "string" },
              "avoid_symmetry": { "type": "boolean" }
            },
            "additionalProperties": true
          }
        }
      }
    }
  }
}
